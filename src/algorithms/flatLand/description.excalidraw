    {
      "id": "R9AZrtclHtrj17Ybihq8M",
      "type": "text",
      "x": -339.44047619047586,
      "y": 532.333333333333,
      "width": 1142.987548828125,
      "height": 630,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 488979078,
      "version": 109,
      "versionNonce": 995320538,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774299524396,
      "link": null,
      "locked": false,
      "text": "The distance to the nearest space station for each city is listed below:\n\n· c[0] has distance 0 km, as it contains a space station.\n· c[1] has distance 1 km to the space station in c[0].\n· c[2] has distance 2 km to the space stations in c[0] and c[4].\n· c[3] has distance 1 km to the space station in c[4].\n· c[4] has distance 0 km, as it contains a space station.\n\nWe then take max(0, 1, 2,1,0) =2.\n\nSample Input\n    5  [0, 4]\n\nSample Output\n    2\n\nExplanation\nIn this sample, n = m so every city has space station and we print 0 as our answer.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The distance to the nearest space station for each city is listed below:\n\n· c[0] has distance 0 km, as it contains a space station.\n· c[1] has distance 1 km to the space station in c[0].\n· c[2] has distance 2 km to the space stations in c[0] and c[4].\n· c[3] has distance 1 km to the space station in c[4].\n· c[4] has distance 0 km, as it contains a space station.\n\nWe then take max(0, 1, 2,1,0) =2.\n\nSample Input\n    5  [0, 4]\n\nSample Output\n    2\n\nExplanation\nIn this sample, n = m so every city has space station and we print 0 as our answer.",
      "autoResize": true,
      "lineHeight": 1.25
    },
